# dependencies
node_modules/
.pnp
.pnp.js

# next.js build output
.next/
out/

# production build
build/

# environment variables (contains secrets)
.env*.local
.env

# runtime data (user data, sessions, etc.)
data/

# large binary files
bin/

# runtime progress files
process-progress.json
download-progress.json

# video files (too large for git, deploy separately)
public/content/*/video.mp4

# python cache
__pycache__/
*.pyc

# IDE
.trae/
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
.DS_Store
desktop.ini

# logs
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript cache
*.tsbuildinfo
next-env.d.ts
