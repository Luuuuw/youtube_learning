# MiniMax API Key（必填，初翻/查词依赖）
MINIMAX_API_KEY=your_minimax_api_key_here

# DeepSeek API Key（必填，审校 + 补译漏条；缺失则降级为纯 MiniMax 模式）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 初始管理员密码（可选）
# 不设置则首次启动生成 16 位随机密码到 data/.initial-admin-password.txt
# Render 上首次部署建议设一个，部署成功后删除该环境变量
# INITIAL_ADMIN_PASSWORD=

# 视频 CDN base URL（Phase 1 上线 R2 后必填）
# 例：https://pub-xxx.r2.dev 或自定义域 https://videos.yourdomain.com
# 留空则视频从本地 /public/content/ 加载（开发模式）
# NEXT_PUBLIC_VIDEO_CDN_BASE=
